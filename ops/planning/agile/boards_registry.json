{
  "schema_version": "1.0.0",
  "description": "Canonical board definitions and rendering rules. Tasks are selected from tasks_master.json via board type/id filters.",
  "default_framework_template": "gateflow_v1",
  "framework_templates": {
    "kanban_v1": {
      "description": "Simple Kanban lifecycle.",
      "status_columns": [
        "Backlog",
        "Ready",
        "In Progress",
        "Review",
        "Done",
        "Blocked"
      ],
      "wip_limits": {
        "In Progress": 3,
        "Review": 2
      }
    },
    "gateflow_v1": {
      "description": "Luvatrix GateFlow stage-gated workflow (default).",
      "status_columns": [
        "Intake",
        "Success Criteria Spec",
        "Safety Tests Spec",
        "Implementation Tests Spec",
        "Edge Case Tests Spec",
        "Prototype Stage 1",
        "Prototype Stage 2+",
        "Verification Review",
        "Integration Ready",
        "Done",
        "Blocked"
      ],
      "wip_limits": {
        "Prototype Stage 1": 3,
        "Prototype Stage 2+": 3,
        "Verification Review": 2
      }
    }
  },
  "render_defaults": {
    "status_columns": [
      "Intake",
      "Success Criteria Spec",
      "Safety Tests Spec",
      "Implementation Tests Spec",
      "Edge Case Tests Spec",
      "Prototype Stage 1",
      "Prototype Stage 2+",
      "Verification Review",
      "Integration Ready",
      "Done",
      "Blocked"
    ],
    "sort_order": [
      "priority",
      "id"
    ],
    "card_fields": [
      "id",
      "title",
      "status",
      "milestone_id",
      "depends_on",
      "cost_bucket",
      "cost_score",
      "cost_confidence"
    ],
    "wip_limits": {
      "Prototype Stage 1": 3,
      "Prototype Stage 2+": 3,
      "Verification Review": 2
    }
  },
  "board_types": {
    "milestone": {
      "description": "One board per milestone for execution tracking.",
      "default_swimlane": "specialist"
    },
    "team": {
      "description": "Cross-milestone board for domain teams.",
      "default_swimlane": "milestone_id"
    },
    "specialist": {
      "description": "Cross-milestone board for specialist roles.",
      "default_swimlane": "milestone_id"
    },
    "backlog": {
      "description": "Misc backlog ledger board for carryover/unscoped tickets.",
      "default_swimlane": "bucket"
    }
  },
