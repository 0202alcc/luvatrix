{
  "planes_protocol_version": "0.2.0-dev",
  "app": {
    "id": "examples.planes_v2_poc",
    "title": "Planes v2 Web Scroll + Section Cut Demo",
    "icon": "assets/logo.svg",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "planes": [
    {
      "id": "world",
      "default_frame": "screen_tl",
      "background": {"color": "#0d1720"},
      "plane_global_z": 0,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "px", "value": 1800},
        "height": {"unit": "px", "value": 4200}
      }
    },
    {
      "id": "content",
      "default_frame": "screen_tl",
      "background": {"color": "#0d1720"},
      "plane_global_z": 6,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "px", "value": 1800},
        "height": {"unit": "px", "value": 4200}
      }
    },
    {
      "id": "detail",
      "default_frame": "screen_tl",
      "background": {"color": "#0d1720"},
      "plane_global_z": 3,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "px", "value": 1800},
        "height": {"unit": "px", "value": 4200}
      }
    }
  ],
  "routes": [
    {
      "id": "main",
      "default": true,
      "active_planes": ["world", "detail", "content"]
    }
  ],
  "themes": {
    "default": {"background": "#0d1720"},
    "sunset": {"background": "#6a1b2e"}
  },
  "scripts": [
    {
      "id": "handlers",
      "lang": "python",
      "src": "scripts/handlers.py"
    }
  ],
  "components": [
    {
      "id": "world_base",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "world",
      "component_local_z": -5,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1800}, "height": {"unit": "px", "value": 4200}},
      "z_index": -5,
      "props": {"svg": "assets/page_canvas.svg"}
    },
    {
      "id": "page_title",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 20,
      "blend_mode": "absolute_rgba",
      "position": {"x": 120, "y": 88, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1500}, "height": {"unit": "px", "value": 46}},
      "z_index": 20,
      "props": {
        "text": "Scrollable Page Demo (main plane camera)",
        "color_hex": "#f5fbff",
        "font_size_px": 30
      }
    },
    {
      "id": "page_subtitle",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 20,
      "blend_mode": "absolute_rgba",
      "position": {"x": 120, "y": 142, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1650}, "height": {"unit": "px", "value": 30}},
      "z_index": 20,
      "props": {
        "text": "Scroll up/down anywhere on the page. In the section cut, wheel input scrolls the lower plane only.",
        "color_hex": "#9eb8d8",
        "font_size_px": 18
      }
    },
    {
      "id": "hero_block",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 120, "y": 220, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1480}, "height": {"unit": "px", "value": 380}},
      "z_index": 6,
      "props": {"svg": "assets/blue_rect.svg"}
    },
    {
      "id": "copy_block_top",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 180, "y": 700, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1320}, "height": {"unit": "px", "value": 300}},
      "z_index": 6,
      "props": {"svg": "assets/teal_rect.svg"}
    },
    {
      "id": "copy_block_mid",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 220, "y": 1100, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1260}, "height": {"unit": "px", "value": 260}},
      "z_index": 6,
      "props": {"svg": "assets/green_rect.svg"}
    },
    {
      "id": "section_cut_title",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 24,
      "blend_mode": "absolute_rgba",
      "position": {"x": 180, "y": 1520, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1500}, "height": {"unit": "px", "value": 30}},
      "z_index": 24,
      "props": {
        "text": "Section cut: lower plane scrolls only while pointer is inside this viewport",
        "color_hex": "#ffe4bf",
        "font_size_px": 20
      }
    },
    {
      "id": "detail_canvas",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "detail",
      "component_local_z": 4,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1600}, "height": {"unit": "px", "value": 1800}},
      "z_index": 4,
      "props": {"svg": "assets/section_cut_content.svg"}
    },
    {
      "id": "section_cut_viewport",
      "type": "viewport",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 28,
      "blend_mode": "absolute_rgba",
      "position": {"x": 180, "y": 1580, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1240}, "height": {"unit": "px", "value": 450}},
      "z_index": 28,
      "props": {
        "clip": true,
        "content_ref": "detail_canvas",
        "scroll": {"x": 0, "y": 0},
        "scroll_speed": {"x": 1.0, "y": 1.0}
      }
    },
    {
      "id": "section_help",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 29,
      "blend_mode": "absolute_rgba",
      "position": {"x": 190, "y": 2048, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1500}, "height": {"unit": "px", "value": 24}},
      "z_index": 29,
      "props": {
        "text": "Move pointer outside this cutout to return to page scrolling.",
        "color_hex": "#d6ecff",
        "font_size_px": 16
      }
    },
    {
      "id": "copy_block_lower_1",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 180, "y": 2190, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1320}, "height": {"unit": "px", "value": 340}},
      "z_index": 6,
      "props": {"svg": "assets/orange_rect.svg"}
    },
    {
      "id": "copy_block_lower_2",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 240, "y": 2660, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1260}, "height": {"unit": "px", "value": 370}},
      "z_index": 6,
      "props": {"svg": "assets/teal_rect.svg"}
    },
    {
      "id": "copy_block_lower_3",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 160, "y": 3180, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1380}, "height": {"unit": "px", "value": 420}},
      "z_index": 6,
      "props": {"svg": "assets/blue_rect.svg"}
    },
    {
      "id": "bottom_label",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 24,
      "blend_mode": "absolute_rgba",
      "position": {"x": 200, "y": 3680, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1400}, "height": {"unit": "px", "value": 30}},
      "z_index": 24,
      "props": {
        "text": "Bottom of page. Camera scroll confirms full-page vertical behavior.",
        "color_hex": "#f5fbff",
        "font_size_px": 20
      }
    }
  ]
}
