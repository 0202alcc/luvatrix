{
  "planes_protocol_version": "0.1.0",
  "app": {
    "id": "examples.planes_v2_poc",
    "title": "Planes v2 Scrolling Demo",
    "icon": "assets/logo.svg",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "plane": {
    "id": "main",
    "default_frame": "screen_tl",
    "background": {
      "color": "#0d1720"
    }
  },
  "themes": {
    "default": {
      "background": "#0d1720"
    },
    "sunset": {
      "background": "#6a1b2e"
    }
  },
  "scripts": [
    {
      "id": "handlers",
      "lang": "python",
      "src": "scripts/handlers.py"
    }
  ],
  "components": [
    {
      "id": "scroll_canvas",
      "type": "svg",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 2400}, "height": {"unit": "px", "value": 1800}},
      "z_index": -1,
      "props": {"svg": "assets/scroll_canvas.svg"}
    },
    {
      "id": "title",
      "type": "text",
      "position": {"x": 0, "y": 18, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 700}, "height": {"unit": "px", "value": 34}},
      "z_index": 40,
      "props": {
        "text": "Planes v2 Main-Plane Scroll Demo",
        "color_hex": "#f5fbff",
        "font_size_px": 22,
        "align": "center"
      }
    },
    {
      "id": "subtitle",
      "type": "text",
      "position": {"x": 0, "y": 52, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1080}, "height": {"unit": "px", "value": 24}},
      "z_index": 40,
      "props": {
        "text": "Single scroll surface only. Wheel/trackpad anywhere in the canvas area to pan the main page camera.",
        "color_hex": "#9eb8d8",
        "font_size_px": 15,
        "align": "center"
      }
    },
    {
      "id": "content_viewport",
      "type": "viewport",
      "position": {"x": 40, "y": 96, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1520}, "height": {"unit": "px", "value": 760}},
      "z_index": 20,
      "functions": {"on_scroll": "handlers::record_scroll"},
      "props": {
        "clip": true,
        "content_ref": "scroll_canvas",
        "scroll": {"x": 0, "y": 0},
        "scroll_speed": {"x": 1.0, "y": 1.0}
      }
    },
    {
      "id": "reset_button_bg",
      "type": "svg",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 260}, "height": {"unit": "px", "value": 52}},
      "z_index": 45,
      "functions": {"on_press_single": "handlers::reset_scroll"},
      "props": {"svg": "assets/button_bg.svg", "align": "center", "v_align": "bottom", "margin_bottom_px": 20}
    },
    {
      "id": "reset_button",
      "type": "text",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 260}, "height": {"unit": "px", "value": 52}},
      "z_index": 46,
      "functions": {"on_press_single": "handlers::reset_scroll"},
      "props": {"text": "Reset Scroll", "color_hex": "#ffffff", "font_size_px": 18, "align": "center", "v_align": "bottom", "margin_bottom_px": 20}
    }
  ]
}
