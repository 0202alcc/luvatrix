{
  "planes_protocol_version": "0.2.0-dev",
  "app": {
    "id": "examples.planes_v2_poc",
    "title": "Planes v2 Scrolling Demo",
    "icon": "assets/logo.svg",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "planes": [
    {
      "id": "world",
      "default_frame": "screen_tl",
      "background": {
        "color": "#0d1720"
      },
      "plane_global_z": 0,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "px", "value": 2400},
        "height": {"unit": "px", "value": 1800}
      }
    },
    {
      "id": "content",
      "default_frame": "screen_tl",
      "background": {
        "color": "#0d1720"
      },
      "plane_global_z": 5,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "px", "value": 2400},
        "height": {"unit": "px", "value": 1800}
      }
    }
  ],
  "routes": [
    {
      "id": "main",
      "default": true,
      "active_planes": ["world", "content"]
    }
  ],
  "themes": {
    "default": {
      "background": "#0d1720"
    },
    "sunset": {
      "background": "#6a1b2e"
    }
  },
  "scripts": [
    {
      "id": "handlers",
      "lang": "python",
      "src": "scripts/handlers.py"
    }
  ],
  "components": [
    {
      "id": "world_base",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "world",
      "component_local_z": -5,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 2400}, "height": {"unit": "px", "value": 1800}},
      "z_index": -5,
      "props": {"svg": "assets/scroll_canvas.svg"}
    },
    {
      "id": "panel_a",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 2,
      "blend_mode": "absolute_rgba",
      "position": {"x": 120, "y": 180, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 760}, "height": {"unit": "px", "value": 420}},
      "z_index": 2,
      "props": {"svg": "assets/blue_rect.svg"}
    },
    {
      "id": "panel_b",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 2,
      "blend_mode": "absolute_rgba",
      "position": {"x": 1080, "y": 220, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 900}, "height": {"unit": "px", "value": 460}},
      "z_index": 2,
      "props": {"svg": "assets/teal_rect.svg"}
    },
    {
      "id": "panel_c",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 2,
      "blend_mode": "absolute_rgba",
      "position": {"x": 1640, "y": 1020, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 700}, "height": {"unit": "px", "value": 420}},
      "z_index": 2,
      "props": {"svg": "assets/orange_rect.svg"}
    },
    {
      "id": "panel_d",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 2,
      "blend_mode": "absolute_rgba",
      "position": {"x": 260, "y": 1220, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 820}, "height": {"unit": "px", "value": 460}},
      "z_index": 2,
      "props": {"svg": "assets/green_rect.svg"}
    },
    {
      "id": "world_label_top",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 80, "y": 70, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 640}, "height": {"unit": "px", "value": 32}},
      "z_index": 6,
      "props": {"text": "World origin area (0,0)", "color_hex": "#d4ebff", "font_size_px": 24}
    },
    {
      "id": "world_label_far_right",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 1760, "y": 180, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 600}, "height": {"unit": "px", "value": 32}},
      "z_index": 6,
      "props": {"text": "Far right component zone", "color_hex": "#ffe9cf", "font_size_px": 24}
    },
    {
      "id": "world_label_bottom",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "content",
      "component_local_z": 6,
      "blend_mode": "absolute_rgba",
      "position": {"x": 1700, "y": 1700, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 640}, "height": {"unit": "px", "value": 32}},
      "z_index": 6,
      "props": {"text": "Bottom-right world edge", "color_hex": "#f5fbff", "font_size_px": 24}
    },
    {
      "id": "inset_canvas",
      "type": "svg",
      "attachment_kind": "camera_overlay",
      "component_local_z": 39,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1400}, "height": {"unit": "px", "value": 900}},
      "z_index": 39,
      "props": {"svg": "assets/inset_canvas.svg", "camera_fixed": true}
    },
    {
      "id": "inset_viewport",
      "type": "viewport",
      "attachment_kind": "camera_overlay",
      "component_local_z": 41,
      "blend_mode": "absolute_rgba",
      "position": {"x": 470, "y": 140, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 620}, "height": {"unit": "px", "value": 360}},
      "z_index": 41,
      "props": {
        "clip": true,
        "content_ref": "inset_canvas",
        "scroll": {"x": 0, "y": 0},
        "scroll_speed": {"x": 1.0, "y": 1.0},
        "camera_fixed": true
      }
    },
    {
      "id": "inset_label",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 42,
      "blend_mode": "absolute_rgba",
      "position": {"x": 470, "y": 108, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 620}, "height": {"unit": "px", "value": 24}},
      "z_index": 42,
      "props": {
        "text": "Inset viewport: scroll here first, then page scroll remainder",
        "color_hex": "#ffe4bf",
        "font_size_px": 16,
        "camera_fixed": true
      }
    },
    {
      "id": "title",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 40,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 18, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 780}, "height": {"unit": "px", "value": 34}},
      "z_index": 40,
      "props": {
        "text": "Planes v2 Nested Scroll Demo",
        "color_hex": "#f5fbff",
        "font_size_px": 22,
        "align": "center",
        "camera_fixed": true
      }
    },
    {
      "id": "subtitle",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 40,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 52, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 1160}, "height": {"unit": "px", "value": 24}},
      "z_index": 40,
      "props": {
        "text": "Scroll over inset viewport to pan inset content; when saturated, remainder bubbles to full page camera scroll.",
        "color_hex": "#9eb8d8",
        "font_size_px": 15,
        "align": "center",
        "camera_fixed": true
      }
    },
    {
      "id": "reset_button_bg",
      "type": "svg",
      "attachment_kind": "camera_overlay",
      "component_local_z": 45,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 260}, "height": {"unit": "px", "value": 52}},
      "z_index": 45,
      "functions": {"on_press_single": "handlers::reset_scroll"},
      "props": {
        "svg": "assets/button_bg.svg",
        "align": "center",
        "v_align": "bottom",
        "margin_bottom_px": 20,
        "camera_fixed": true
      }
    },
    {
      "id": "reset_button",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 46,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {"width": {"unit": "px", "value": 260}, "height": {"unit": "px", "value": 52}},
      "z_index": 46,
      "functions": {"on_press_single": "handlers::reset_scroll"},
      "props": {
        "text": "Reset Scroll",
        "color_hex": "#ffffff",
        "font_size_px": 18,
        "align": "center",
        "v_align": "bottom",
        "margin_bottom_px": 20,
        "camera_fixed": true
      }
    }
  ]
}
