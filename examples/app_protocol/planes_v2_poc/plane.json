{
  "planes_protocol_version": "0.2.0-dev",
  "app": {
    "id": "examples.planes_v2_poc",
    "title": "Planes v2 Index Plane Foundation",
    "icon": "assets/logo.svg",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "planes": [
    {
      "id": "index",
      "default_frame": "screen_tl",
      "background": {"color": "#0d1720"},
      "plane_global_z": 0,
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "vw", "value": 100},
        "height": {"unit": "vh", "value": 300}
      }
    }
  ],
  "routes": [
    {
      "id": "main",
      "default": true,
      "active_planes": ["index"]
    }
  ],
  "themes": {
    "default": {"background": "#0d1720"}
  },
  "scripts": [
    {
      "id": "handlers",
      "lang": "python",
      "src": "scripts/handlers.py"
    }
  ],
  "components": [
    {
      "id": "index_gradient_bg",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "index",
      "component_local_z": 0,
      "blend_mode": "absolute_rgba",
      "position": {"x": 0, "y": 0, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "vw", "value": 100},
        "height": {"unit": "vh", "value": 300}
      },
      "z_index": 0,
      "props": {"svg": "assets/index_plane_gradient.svg"}
    },
    {
      "id": "foundation_label",
      "type": "text",
      "attachment_kind": "plane",
      "attach_to": "index",
      "component_local_z": 30,
      "blend_mode": "absolute_rgba",
      "position": {"x": 6, "y": 8, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "vw", "value": 88},
        "height": {"unit": "vh", "value": 4}
      },
      "z_index": 30,
      "props": {
        "text": "Index Plane: 100vw x 300vh with centered section cut",
        "color_hex": "#e9f4ff",
        "font_size_px": 26
      }
    },
    {
      "id": "section_cut",
      "type": "viewport",
      "attachment_kind": "plane",
      "attach_to": "index",
      "component_local_z": 40,
      "blend_mode": "absolute_rgba",
      "position": {"x": 40, "y": 130, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "vh", "value": 40},
        "height": {"unit": "vh", "value": 40}
      },
      "z_index": 40,
      "props": {
        "clip": true,
        "content_ref": "index_gradient_bg",
        "scroll": {"x": 0, "y": 0},
        "scroll_speed": {"x": 1.0, "y": 1.0}
      }
    },
    {
      "id": "section_cut_frame",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "index",
      "component_local_z": 45,
      "blend_mode": "absolute_rgba",
      "position": {"x": 40, "y": 130, "frame": "screen_tl"},
      "size": {
        "width": {"unit": "vh", "value": 40},
        "height": {"unit": "vh", "value": 40}
      },
      "z_index": 45,
      "props": {"svg": "assets/section_cut_frame.svg"}
    }
  ]
}
