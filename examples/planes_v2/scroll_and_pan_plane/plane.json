{
  "planes_protocol_version": "0.2.0-dev",
  "app": {
    "id": "examples.scroll_and_pan_plane",
    "title": "Scroll And Pan Plane",
    "icon": "assets/logo.svg",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "planes": [
    {
      "id": "main",
      "default_frame": "screen_tl",
      "background": {
        "color": "#0f1b2a"
      },
      "plane_global_z": 0,
      "position": {
        "x": 0,
        "y": 0,
        "frame": "screen_tl"
      },
      "size": {
        "width": {
          "unit": "px",
          "value": 900
        },
        "height": {
          "unit": "px",
          "value": 500
        }
      }
    }
  ],
  "routes": [
    {
      "id": "main",
      "default": true,
      "active_planes": [
        "main"
      ]
    }
  ],
  "themes": {
    "default": {
      "background": "#0f1b2a"
    },
    "training_alt": {
      "background": "#1f3047"
    }
  },
  "scripts": [
    {
      "id": "handlers",
      "lang": "python",
      "src": "scripts/handlers.py"
    }
  ],
  "components": [
    {
      "id": "title_text",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 90,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": 12,
        "y": 8,
        "frame": "screen_tl"
      },
      "size": {
        "width": {
          "unit": "px",
          "value": 540
        },
        "height": {
          "unit": "px",
          "value": 28
        }
      },
      "props": {
        "text": "scroll and pan plane",
        "color_hex": "#eaf5ff",
        "font_size_px": 18
      }
    },
    {
      "id": "status_text",
      "type": "text",
      "attachment_kind": "camera_overlay",
      "component_local_z": 91,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": 12,
        "y": 38,
        "frame": "screen_tl"
      },
      "size": {
        "width": {
          "unit": "px",
          "value": 620
        },
        "height": {
          "unit": "px",
          "value": 24
        }
      },
      "props": {
        "text": "ready",
        "color_hex": "#9bc9f8",
        "font_size_px": 15
      }
    },
    {
      "id": "scroll_canvas",
      "type": "svg",
      "attachment_kind": "plane",
      "attach_to": "main",
      "component_local_z": 1,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": 320,
        "y": 60,
        "frame": "screen_tl"
      },
      "size": {
        "width": {
          "unit": "px",
          "value": 640
        },
        "height": {
          "unit": "px",
          "value": 420
        }
      },
      "functions": {
        "on_scroll": "handlers::scroll_plane"
      },
      "props": {
        "svg": "assets/canvas.svg"
      }
    },
    {
      "id": "scroll_viewport",
      "type": "viewport",
      "attachment_kind": "plane",
      "attach_to": "main",
      "component_local_z": 2,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": 320,
        "y": 60,
        "frame": "screen_tl"
      },
      "size": {
        "width": {
          "unit": "px",
          "value": 260
        },
        "height": {
          "unit": "px",
          "value": 180
        }
      },
      "props": {
        "clip": true,
        "content_ref": "scroll_canvas",
        "scroll": {
          "x": 0,
          "y": 0
        }
      }
    }
  ]
}
