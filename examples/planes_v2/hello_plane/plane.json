{
  "planes_protocol_version": "0.2.0-dev",
  "app": {
    "id": "examples.hello_plane",
    "title": "Hello Plane",
    "icon": "assets/logo.svg",
    "default_frame": "cartesian_center",
    "web": {
      "tab_title": null,
      "tab_icon": null
    }
  },
  "planes": [
    {
      "id": "main",
      "default_frame": "cartesian_center",
      "background": {
        "color": "#F6F1E8"
      },
      "plane_global_z": 0,
      "position": {
        "x": 0,
        "y": 0,
        "frame": "screen_tl"
      },
      "size": {
        "width": "100vw",
        "height": "100vh"
      }
    }
  ],
  "routes": [
    {
      "id": "main",
      "default": true,
      "active_planes": [
        "main"
      ]
    }
  ],
  "themes": {
    "default": {
      "background": "#F6F1E8"
    }
  },
  "scripts": [],
  "components": [
    {
      "id": "title_text",
      "type": "text",
      "attach_to": "plane:main",
      "component_local_z": 0,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": "50vw",
        "y": "10vh",
        "frame": "screen_tl"
      },
      "anchor": {
        "x": "50%",
        "y": 0,
        "frame_reference": "screen_tl"
      },
      "size": {
        "width": "auto",
        "height": "auto"
      },
      "props": {
        "text": "Hello Plane!",
        "font_size_px": 54,
        "color_hex": "#5B1210",
        "text_origin_mode": "frame_reference"
      }
    },
    {
      "id": "subtitle_text",
      "type": "text",
      "attach_to": "plane:main",
      "component_local_z": 0,
      "blend_mode": "absolute_rgba",
      "position": {
        "x": "50vw",
        "y": "24vh",
        "frame": "screen_tl"
      },
      "anchor": {
        "x": "50%",
        "y": 0,
        "frame_reference": "screen_tl"
      },
      "size": {
        "width": "auto",
        "height": "auto"
      },
      "props": {
        "text": "Welcome to the world of Planes!",
        "font_size_px": 27,
        "color_hex": "#9A3A34",
        "text_origin_mode": "frame_reference"
      }
    },
    {
      "id": "stained_glass_button",
      "type": "button",
      "attach_to": "plane:main",
      "component_local_z": 6,
      "blend_mode": "delta_rgba",
      "position": {
        "x": "50vw",
        "y": "50vh",
        "frame": "screen_tl"
      },
      "anchor": {
        "x": "50%",
        "y": "50%",
        "frame_reference": "screen_tl"
      },
      "size": {
        "width": 280,
        "height": 84
      },
      "functions": {
        "on_press_single": "handlers::cycle_hover_profile"
      },
      "props": {
        "material_profile": "water_button",
        "draggable": false,
        "label": "Profile 1/5",
        "label_color_hex": "#FFF6F4"
      }
    }
  ]
}
